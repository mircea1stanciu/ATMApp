{
  "name": "cypress-tests",
  "version": "1.0.0",
  "description": "Cypress E2E tests for registration flow",
  "main": "index.js",
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:chrome": "cypress run --browser chrome",
    "cypress:run:firefox": "cypress run --browser firefox",
    "cypress:run:edge": "cypress run --browser edge",
    "test": "cypress run",
    "test:registration": "cypress run --spec 'cypress/e2e/registration.cy.js'",
    "test:admin-registration": "cypress run --spec 'cypress/e2e/admin-registration.cy.js'",
    "test:bdd:gherkin": "cypress run --spec 'cypress/e2e/features/TC01_LoginBDD_TS.feature'",
    "test:bdd:native": "cypress run --spec 'cypress/e2e/TC01_LoginAdmin_BDD_Fixed.cy.ts'",
    "test:bdd:login": "npm run test:bdd:gherkin",
    "test:bdd:all": "cypress run --spec 'cypress/e2e/features/**/*.feature'",
    "test:bdd:headed": "cypress run --spec 'cypress/e2e/features/**/*.feature' --headed",
    "test:headed": "cypress run --headed",
    "test:chrome": "cypress run --browser chrome --headed"
  },
  "keywords": [
    "cypress",
    "e2e",
    "testing",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@badeball/cypress-cucumber-preprocessor": "^24.0.0",
    "@cypress/webpack-preprocessor": "^7.0.2",
    "@types/node": "^25.0.3",
    "babel-loader": "^10.0.0",
    "cypress": "^15.7.1",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.103.0"
  }
}
