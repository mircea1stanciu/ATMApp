# env vars — NU adăuga niciodată în git!
# Copiază în .env și completează valorile reale

APP_ENV=development
SECRET_KEY=replace-with-a-long-random-string-minimum-32-chars

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://testmanager:testmanager@localhost:5432/testmanager

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# CORS (frontend URL)
# CORS_ORIGINS=["http://localhost:5173"]

# GitHub PAT (Personal Access Token) — scope: repo (read)
GITHUB_TOKEN=ghp_replace_with_your_token

# Docker runner limits
DOCKER_RUNNER_NETWORK=none
DOCKER_RUNNER_MEM_LIMIT=512m
DOCKER_RUNNER_CPU_QUOTA=50000
