# ================================
# UnifiedWork Environment Variables
# ================================

# Database
DATABASE_URL=postgresql://unifiedwork:password@localhost:5432/unifiedwork
REDIS_URL=redis://localhost:6379/0
# API Keys
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here  # Optional

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-generate-a-random-one
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
APP_NAME=UnifiedWork
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@unifiedwork.io

# AI Configuration (Cost-Optimized)
# Use gpt-4o-mini for cheapest option ($0.15/1M input, $0.60/1M output)
# About $0.10-$0.20 per 1,000 chat messages
AI_MODEL=gpt-4o-mini
AI_TEMPERATURE=0.7  # Balance between creativity and consistency
AI_MAX_TOKENS=1000  # Lower = cheaper (was 2000). Increase if responses get cut off

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
UPLOAD_DIR=uploads/

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Subscription Plans
FREE_PLAN_USER_LIMIT=10
FREE_PLAN_AI_REQUESTS=100
BASIC_PLAN_USER_LIMIT=20
BASIC_PLAN_AI_REQUESTS=500
PREMIUM_PLAN_USER_LIMIT=50
PREMIUM_PLAN_AI_REQUESTS=2000

# WebSocket
WEBSOCKET_ENABLED=True

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/unifiedwork.log

# Analytics
ANALYTICS_ENABLED=True
MIXPANEL_TOKEN=your-mixpanel-token

# Integrations
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
